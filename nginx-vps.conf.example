# ─────────────────────────────────────────────────────────────────────────────
#  Bloco de configuração do Nginx DO HOST (VPS) para dj.maselcorp.com.br
#
#  Coloque em: /etc/nginx/sites-available/dj.maselcorp.com.br
#  Ative com:  ln -s /etc/nginx/sites-available/dj.maselcorp.com.br \
#                     /etc/nginx/sites-enabled/
#
#  SSL: certbot --nginx -d dj.maselcorp.com.br
#  Teste: nginx -t && systemctl reload nginx
# ─────────────────────────────────────────────────────────────────────────────

# ── HTTP — redireciona para HTTPS ─────────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name dj.maselcorp.com.br;

    location /.well-known/acme-challenge/ { root /var/www/certbot; }
    location / { return 301 https://$host$request_uri; }
}

# ── HTTPS ─────────────────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name dj.maselcorp.com.br;

    # Certificados gerados pelo Certbot
    ssl_certificate     /etc/letsencrypt/live/dj.maselcorp.com.br/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dj.maselcorp.com.br/privkey.pem;
    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    # Cabeçalhos de segurança
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options        "SAMEORIGIN"                    always;
    add_header X-Content-Type-Options "nosniff"                       always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin" always;

    # Tamanho máximo de upload
    client_max_body_size 20M;

    # ── Proxy para o container frontend do Projectfy (porta 8082) ───────────
    location / {
        proxy_pass         http://127.0.0.1:8082;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}


# ─────────────────────────────────────────────────────────────────────────────
#  MAPA DE PORTAS DA VPS (para não conflitar com outros sistemas)
#
#  Sistema              Porta local   Subdomínio
#  ─────────────────────────────────────────────
#  Status Energy        8081          status.maselcorp.com.br (exemplo)
#  Projectfy (este)     8082          dj.maselcorp.com.br
#  Próximo sistema      8083          (reservar conforme necessidade)
#
#  80 / 443 → exclusivos do Nginx HOST (proxy reverso)
#  Nenhuma porta exposta ao 0.0.0.0 — apenas 127.0.0.1
# ─────────────────────────────────────────────────────────────────────────────
