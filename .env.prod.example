# ─────────────────────────────────────────────────────────────────
#  Projectfy — variáveis de ambiente para produção
#  Copie para .env.prod, preencha e NUNCA comite esse arquivo.
# ─────────────────────────────────────────────────────────────────

# Senha do PostgreSQL (deve ser forte em produção)
POSTGRES_PASSWORD=c2edf2b493bc059b068b7d947b21ed74

# Segredos JWT — gere com: openssl rand -hex 64
JWT_SECRET=45038dbd28a2d02c3163d5a5eabd96ce384cc95b9b7d6fb4e3329f90dbddf419
JWT_REFRESH_SECRET=e616815285a242cad46ddbe84117826dbc1b93163fd96ac5cd190d152c94bb96

# Porta local que o proxy reverso do host vai apontar para dj.maselcorp.com.br
# Não use 8081 (Status Energy) nem 80/443 (reservados ao proxy do host)
FRONTEND_PORT=8082

# URL publica do app (links em e-mails)
APP_PUBLIC_URL=https://dj.maselcorp.com.br
APP_NAME=Docject

# SMTP — Zoho Mail (dominio proprio @maselcorp.com.br)
# Confira o host exato em: Zoho Mail → Configuracoes → Contas → Detalhes do servidor
#
# Opcao A — porta 587 com STARTTLS (recomendado):
#   SMTP_HOST=smtppro.zoho.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
# Opcao B — porta 465 com SSL:
#   SMTP_HOST=smtppro.zoho.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#
# Plano gratuito/pessoal: smtp.zoho.com | Plano pago com dominio: smtppro.zoho.com
# Com 2FA ativo: use senha de app (Zoho → Seguranca → Senhas especificas de app)
# SMTP_USER = e-mail completo | SMTP_FROM deve ser o mesmo e-mail ou alias autorizado
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contato@maselcorp.com.br
SMTP_PASS=
SMTP_FROM=Docject <contato@maselcorp.com.br>
