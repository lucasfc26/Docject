generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  FINANCIAL
  CLIENT
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  PAUSED
  WAITING_CLIENT
  COMPLETED
  CANCELLED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
}

enum TransactionStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  phone         String?
  address       String?
  passwordHash  String
  role          UserRole       @default(MANAGER)
  client        Client?        @relation("ClientPortalUsers", fields: [clientId], references: [id])
  clientId      String?
  ownedClients  Client[]       @relation("ClientOwner")
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
}

model Client {
  id        String          @id @default(uuid())
  name      String
  segment   String?
  health    String          @default("STABLE")
  revenue   Decimal         @default(0)
  owner     User?           @relation("ClientOwner", fields: [ownerId], references: [id])
  ownerId   String?
  users     User[]          @relation("ClientPortalUsers")
  contracts Contract[]
  contacts  ClientContact[]
  projects  Project[]
  services  Service[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ClientContact {
  id       String @id @default(uuid())
  name     String
  email    String
  phone    String?
  client   Client @relation(fields: [clientId], references: [id])
  clientId String
}

model Project {
  id        String        @id @default(uuid())
  name      String
  budget    Decimal       @default(0)
  status    ProjectStatus @default(PLANNING)
  progress  Int           @default(0)
  client    Client        @relation(fields: [clientId], references: [id])
  clientId  String
  modules   ProjectModule[]
  comments  Comment[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ProjectModule {
  id                  String                 @id @default(uuid())
  name                String
  progress            Int                    @default(0)
  orderIndex          Int                    @default(0)
  businessDays        Int                    @default(0)
  startDate           DateTime?
  endDate             DateTime?
  value               Decimal                @default(0)
  completed           Boolean                @default(false)
  completedAt         DateTime?
  project             Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId           String
  milestones          Milestone[]
  paymentTransactions FinancialTransaction[]
  appointment         Appointment?
  notification        Notification?
}

model Milestone {
  id        String        @id @default(uuid())
  title     String
  dueDate   DateTime?
  completed Boolean       @default(false)
  module    ProjectModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String
}

model Contract {
  id        String         @id @default(uuid())
  title     String
  value     Decimal        @default(0)
  status    ContractStatus @default(DRAFT)
  client    Client?        @relation(fields: [clientId], references: [id])
  clientId  String?
  versions  ContractVersion[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ContractVersion {
  id         String   @id @default(uuid())
  version    Int
  fileUrl    String?
  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String
}

model FinancialTransaction {
  id        String            @id @default(uuid())
  entity    String
  kind      String            @default("REVENUE")
  amount    Decimal
  status    TransactionStatus @default(PENDING)
  dueDate   DateTime?
  module    ProjectModule?    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String?           @unique
  service   Service?          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId String?
  servicePeriod String?
  createdAt DateTime          @default(now())

  @@unique([serviceId, servicePeriod])
}

model Service {
  id             String                 @id @default(uuid())
  name           String
  description    String?
  monthlyValue   Decimal                @default(0)
  paymentDay     Int
  startDate      DateTime
  active         Boolean                @default(true)
  client         Client                 @relation(fields: [clientId], references: [id])
  clientId       String
  transactions   FinancialTransaction[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model Appointment {
  id        String   @id @default(uuid())
  title     String
  client    String?
  location  String?
  startsAt  DateTime
  endsAt    DateTime?
  notes     String?
  module    ProjectModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String?        @unique
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  type      String   @default("INFO")
  title     String
  read      Boolean  @default(false)
  module    ProjectModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String?        @unique
  createdAt DateTime @default(now())
}

model Resource {
  id        String   @id @default(uuid())
  name      String
  role      String
  capacity  Int      @default(100)
  createdAt DateTime @default(now())
}

model FileUpload {
  id        String   @id @default(uuid())
  filename  String
  url       String
  mimeType  String?
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(uuid())
  body      String
  author    String
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String
  actor     String
  metadata  Json?
  createdAt DateTime @default(now())
}

model SystemSettings {
  id        String   @id @default("system")
  appName   String   @default("Docject")
  timezone  String   @default("America/Fortaleza")
  currency  String   @default("BRL")
  supportPhone String?
  updatedAt DateTime @updatedAt
}

model Feature {
  id         String   @id @default(uuid())
  name       String
  path       String   @unique
  orderIndex Int
  role       UserRole @default(ADMIN)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
